# Provider selection
LLM_PROVIDER=deterministic
DOC_STORE=memory
VECTOR_STORE=memory
CHUNKING_STRATEGY=recursive

# Chunking defaults
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
CHUNK_MAX_RECURSIVE_DEPTH=8
SEMANTIC_CHUNKING_ENABLED=false
SEMANTIC_CHUNKING_SIMILARITY_THRESHOLD=0.78
SEMANTIC_CHUNKING_LLM_REFINEMENT_ENABLED=false

# Retrieval defaults
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.0

# OpenAI-compatible settings (public OpenAI or Azure OpenAI)
LLM_API_KEY=
LLM_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIMENSIONS=1536
LLM_CHAT_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_CHAT_MODEL=gpt-4.1-mini
LLM_SYSTEM_PROMPT=Answer only from the supplied context. If the answer is not present, say you do not know. Always cite sources.

# Multi-source async ingestion
INGESTION_MAX_PARALLELISM=4
JOB_STORE=memory
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AZURE_BLOB_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFeqCnf2bVLxxJ5GMGXaR6Uy0zVdD6K4Qb1ELsK6c3w5Yf5oLU7w4LAx5N9D5GVBv0fKqY4w==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

# MongoDB document store
MONGO_CONNECTION_STRING=mongodb://localhost:27017
MONGO_DATABASE=rag
MONGO_CHUNKS_COLLECTION=chunks
MONGO_DOCUMENTS_COLLECTION=documents
MONGO_JOBS_COLLECTION=ingestion_jobs

# Cosmos DB document store
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=rag
COSMOS_CHUNKS_CONTAINER=chunks
COSMOS_DOCUMENTS_CONTAINER=documents
COSMOS_PARTITION_KEY=/tenantId

# Elasticsearch vector store
ELASTICSEARCH_URI=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=rag-chunks
ELASTICSEARCH_VECTOR_DIMENSIONS=1536

# API
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Resilience
HTTP_TIMEOUT_SECONDS=60
HTTP_RETRY_COUNT=3
HTTP_RETRY_BACKOFF_SECONDS=2
