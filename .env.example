# Provider selection
LLM_PROVIDER=deterministic
DOC_STORE=memory
VECTOR_STORE=memory
CHUNKING_STRATEGY=recursive

# Chunking defaults
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
CHUNK_MAX_RECURSIVE_DEPTH=8
SEMANTIC_CHUNKING_ENABLED=false
SEMANTIC_CHUNKING_SIMILARITY_THRESHOLD=0.78
SEMANTIC_CHUNKING_LLM_REFINEMENT_ENABLED=false

# Retrieval defaults
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.0

# OpenAI settings
OPENAI_API_KEY=
OPENAI_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Azure OpenAI settings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_CHAT_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT=

# MongoDB document store
MONGO_CONNECTION_STRING=mongodb://localhost:27017
MONGO_DATABASE=rag
MONGO_CHUNKS_COLLECTION=chunks
MONGO_DOCUMENTS_COLLECTION=documents

# Cosmos DB document store
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=rag
COSMOS_CHUNKS_CONTAINER=chunks
COSMOS_DOCUMENTS_CONTAINER=documents
COSMOS_PARTITION_KEY=/tenantId

# Elasticsearch vector store
ELASTICSEARCH_URI=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=rag-chunks
ELASTICSEARCH_VECTOR_DIMENSIONS=1536

# API
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Resilience
HTTP_TIMEOUT_SECONDS=60
HTTP_RETRY_COUNT=3
HTTP_RETRY_BACKOFF_SECONDS=2
